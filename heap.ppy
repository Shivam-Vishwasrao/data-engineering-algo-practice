import heapq

nums = [9,2,7,4,1]
heapq.heapify(nums)
print(nums)

print("Smallest Element:", heapq.heappop(nums))
print(nums)

# FIND THE 2ND LARGEST ELEMENT IN THE LIST
List = [5,1,9,3,7]
k = 2

def kthLargest(List, k):
    heap = []

    for num in List:
        heapq.heappush(heap, num)

        if len(heap) > k:
            heapq.heappop(heap)
    return heap[0]

print(kthLargest(List, k))
hp = heapq.nlargest(k, List)
print(hp[1])